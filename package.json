{
  "name": "versatiles-documentation",
  "version": "1.0.0",
  "description": "Documentation for VersaTiles",
  "homepage": "https://github.com/versatiles-org/versatiles-documentation#readme",
  "bugs": {
    "url": "https://github.com/versatiles-org/versatiles-documentation/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/versatiles-org/versatiles-documentation.git"
  },
  "scripts": {
    "build": "npm run validate:showcases && npm run build:showcase-images && npm run build:vitepress",
    "build:vitepress": "vitepress build .",
    "build:showcase-images": "tsx scripts/build-showcase-images.ts",
    "check": "npm run format && npm run lint && npm run build",
    "dev": "vitepress dev .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "vitepress preview .",
    "upgrade": "npm-check-updates -u && npm i",
    "validate:showcases": "tsx scripts/validate-showcases.ts"
  },
  "license": "Unlicense",
  "type": "commonjs",
  "overrides": {
    "vite": ">=7.3.2 <8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "esbuild": "0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "github-slugger": "^2.0.0",
    "js-yaml": "^5.2.1",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.16.0",
    "npm-check-updates": "^22.2.9",
    "prettier": "^3.9.4",
    "sharp": "^0.35.3",
    "tsx": "^4.22.4",
    "typescript-eslint": "^8.62.1",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vue-eslint-parser": "^10.4.1"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true
  }
}
